DATABASE_URL=postgres://autobidd:autobidd@localhost:5432/autobidd?sslmode=disable
SESSION_SECRET=change-me-to-random-32-bytes
PORT=8080
ENV=development

# LLM Provider Configuration
# Provider: "anthropic" or "openai" (openai-compatible)
LLM_PROVIDER=anthropic

# API key for the selected provider
LLM_API_KEY=sk-your-key-here

# Model name (defaults: anthropic=claude-sonnet-4-20250514, openai=gpt-4o)
LLM_MODEL=claude-sonnet-4-20250514

# Optional: override the API base URL
# Useful for OpenAI-compatible services:
#   DeepSeek:     https://api.deepseek.com/v1/chat/completions
#   Ollama:       http://localhost:11434/v1/chat/completions
#   Azure OpenAI: https://your-resource.openai.azure.com/openai/deployments/your-model/chat/completions?api-version=2024-02-01
#   Together AI:  https://api.together.xyz/v1/chat/completions
# LLM_BASE_URL=
